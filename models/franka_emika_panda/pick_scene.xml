<mujoco model="panda pick scene">
  <include file="panda.xml"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    <material name="cube_red" rgba="0.9 0.05 0.05 1" specular="0.1" shininess="0.1"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <!-- Angled workspace camera: at (1.1, 0, 0.9) aimed at (0.5, 0, 0.05).
         xyaxes gives the camera's x (image right) and y (image up) axes;
         MuJoCo cameras look down their local -z. -->
    <camera name="scene_cam" pos="1.1 0 0.9" xyaxes="0 1 0 -0.817 0 0.577" fovy="58"/>

    <!-- Straight-down camera for comparison. -->
    <camera name="top_cam" pos="0.5 0 1.3" xyaxes="1 0 0 0 1 0" fovy="58"/>

    <!-- The object to find: a red cube resting on the floor, within reach. -->
    <body name="cube" pos="0.5 0.0 0.025">
      <freejoint name="cube_free"/>
      <geom name="cube_geom" type="box" size="0.025 0.025 0.025"
            material="cube_red" mass="0.05" friction="1 0.05 0.01"/>
    </body>
  </worldbody>

  <!-- Full-length keyframe: the inherited 'home' key only covers the 9 arm/finger
       joints, so MuJoCo pads the cube's free joint with zeros and teleports it to
       the origin. This one specifies all 16 qpos (7 arm + 2 finger + 7 free). -->
  <keyframe>
    <key name="pick_home"
         qpos="0 0 0 -1.57079 0 1.57079 -0.7853 0.04 0.04  0.5 0 0.025 1 0 0 0"
         ctrl="0 0 0 0 0 0 0 255"/>
  </keyframe>
</mujoco>
